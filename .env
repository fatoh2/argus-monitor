# PostgreSQL
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus

# Redis
REDIS_PORT=6379

# API Service
API_SERVICE_PORT=3000
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION_TIME=60s

# Chain Indexer Service
CHAIN_INDEXER_PORT=3001

# Solana Adapter Service
SOLANA_ADAPTER_PORT=3002
HELIUS_API_KEY=
HELIUS_RPC_URL=
SOLANA_ADAPTER_DATABASE_URL=postgresql://argus:argus@postgres:5432/argus

# Alert Service
ALERT_SERVICE_PORT=3003

# Notification Service
NOTIFICATION_SERVICE_PORT=3004
