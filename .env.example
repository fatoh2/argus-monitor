# =============================================================================
# Argus Monitor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# docker-compose reads .env automatically.
#
# To generate strong secrets, use a command like:
#   openssl rand -base64 32
# =============================================================================

# ---- General ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- API Service (port 3000) ----
# PORT is read by the NestJS app at runtime. Each service in docker-compose
# overrides this via its own *_SERVICE_PORT variable (see below).
PORT=3000
API_SERVICE_PORT=3000
# JWT_SECRET is used for signing access tokens (hardcoded 15m TTL) and refresh tokens (hardcoded 7d TTL)
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET # e.g., openssl rand -base64 32
# JWT_EXPIRATION_TIME overrides the default JWT expiry (default: 60s)
JWT_EXPIRATION_TIME=60s
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Chain Indexer Service (port 3001) ----
CHAIN_INDEXER_PORT=3001

# ---- Solana Adapter Service (port 3002) ----
SOLANA_ADAPTER_PORT=3002
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ---- Alert Service (port 3003) ----
ALERT_SERVICE_PORT=3003

# ---- Notification Service (port 3004) ----
NOTIFICATION_SERVICE_PORT=3004
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ---- RPC Monitor (embedded in solana-adapter-service, port 3005) ----
RPC_MONITOR_PORT=3005
# How often to poll RPC endpoints for health snapshots (milliseconds)
RPC_MONITOR_POLL_INTERVAL_MS=30000
# Maximum number of historical snapshots to retain
RPC_MONITOR_MAX_SNAPSHOTS=10
# Comma-separated list of additional RPC endpoints to monitor
RPC_MONITOR_ENDPOINTS=

# ---- PostgreSQL ----
DATABASE_URL=postgresql://argus:argus@postgres:5432/argus
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Solana Adapter: Rate Limiter ----
RATE_LIMITER_MAX_RPS=10
RATE_LIMITER_MAX_RETRIES=3
RATE_LIMITER_BASE_DELAY_MS=1000
RATE_LIMITER_MAX_DELAY_MS=30000

# ---- Solana Adapter: Circuit Breaker ----
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_MS=30000
CIRCUIT_BREAKER_MAX_RETRIES=3
CIRCUIT_BREAKER_BASE_DELAY_MS=500
CIRCUIT_BREAKER_MAX_DELAY_MS=2000
