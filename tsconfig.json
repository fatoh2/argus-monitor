{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@argus/adapter-sdk": ["packages/adapter-sdk/src"],
      "@argus/shared-types": ["packages/shared-types/src"]
    }
  },
  "include": [
    "apps/*/src/**/*.ts",
    "packages/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
