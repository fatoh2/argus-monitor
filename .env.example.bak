# PostgreSQL\nPOSTGRES_USER=user\nPOSTGRES_PASSWORD=password\nPOSTGRES_DB=dbname\n\n# Redis\nREDIS_URL=redis://localhost:6379\n\n# API Service\nAPI_SERVICE_PORT=3000\n\n# Chain Indexer Service\nCHAIN_INDEXER_SERVICE_PORT=3001\n\n# Solana Adapter Service\nSOLANA_ADAPTER_SERVICE_PORT=3002\n\n# Alert Service\nALERT_SERVICE_PORT=3003\n\n# Notification Service\nNOTIFICATION_SERVICE_PORT=3004\n\n# RPC Monitor Service\nRPC_MONITOR_SERVICE_PORT=3005\n\n# Shared Types (example, adjust as needed)\n# Example for Prisma schema if used directly in services\n# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
